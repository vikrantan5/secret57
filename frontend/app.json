{
  "expo": {
    "name": "ServiceHub",
    "slug": "servicehub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "servicehub",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Multi-vendor marketplace and service booking platform",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.servicehub.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ServiceHub needs your location to show nearby services and sellers."
      }
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#5B7CFF"
      },
      "package": "com.servicehub.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationPermission": "ServiceHub requires location access to show nearby services and sellers."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#5B7CFF"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    }
  }
}